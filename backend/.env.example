# Database connection URL (SQLite or PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./facial_auth.db
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/facial_auth

# Application settings
DEBUG=True

# JWT Token configuration
JWT_SECRET_KEY=super_secret_jwt_key_example_change_me_in_production_32bytes!
JWT_ALGORITHM=HS256

# AES Encryption configuration for storing face embeddings
AES_KEY=default_32byte_aes_secret_key_base64
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Face recognition match threshold (0.0 to 1.0)
FACE_THRESHOLD=0.6

# Admin default password
ADMIN_PASSWORD=admin_secret_password
